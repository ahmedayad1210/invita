# Invita Supabase (dedicated project — NOT Sahar)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=

# Next.js (NEXT_PUBLIC_* required for browser client)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Alias also supported: NEXT_PUBLIC_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=

# App — use the same production URL for both
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin JWT (generate a long random string)
ADMIN_JWT_SECRET=
ADMIN_USERNAME=admin
# Generate: node -e "require('bcryptjs').hash('your-password',12).then(console.log)"
ADMIN_PASSWORD_HASH=

# EmailJS (optional — booking confirmations + contact notifications)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
NEXT_PUBLIC_EMAILJS_CONTACT_TEMPLATE_ID=
