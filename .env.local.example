SUPABASE_SERVICE_ROLE_KEY=

# App — use the same production URL for both
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin JWT (generate a long random string)
ADMIN_JWT_SECRET=
ADMIN_USERNAME=admin
# Generate: node -e "require('bcryptjs').hash('your-password',12).then(console.log)"
ADMIN_PASSWORD_HASH=

# Media library — run supabase/media-assets.sql in Supabase SQL Editor

# Respond.io WhatsApp (optional — booking confirm + reminders)
RESPOND_IO_API_TOKEN=
RESPOND_IO_CHANNEL_ID=
RESPOND_IO_BASE_URL=https://api.respond.io/v2

# Cron — Netlify scheduled function auth for /api/cron/dispatch-notifications
CRON_SECRET=

# IV studio migrations — run in Supabase SQL Editor (in order):
# phase4-platform.sql, media-assets.sql, services-catalog.sql, patients-crm.sql, notifications.sql
# Then sync drip menu: npm run sync:services

# EmailJS (optional — booking confirmations + contact notifications)
